@page "/"
@page "/claims"
@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using TryalTestForMargasoftShared.Lookups
@using TryalTestForMargasoftShared.MedicalClaims
@inject HttpClient Http

<PageTitle>Claims</PageTitle>

<section class="claims-page">
    <div class="page-header">
        <div>
            <p class="eyebrow">Medical claim recovery</p>
            <h1>Claims</h1>
        </div>
        <a class="btn btn-primary" href="claims/create">Create claim</a>
    </div>

    <form class="filter-panel" @onsubmit="SearchClaimsAsync" @onsubmit:preventDefault="true">
        <div class="filter-grid">
            <label>
                <span>Search</span>
                <input class="form-control" placeholder="Claim number, patient, denial..." @bind="search" />
            </label>

            <label>
                <span>Status</span>
                <select class="form-select" @bind="status">
                    <option value="">All statuses</option>
                    @foreach (var option in StatusOptions)
                    {
                        <option value="@option">@FormatStatus(option)</option>
                    }
                </select>
            </label>

            <label>
                <span>Priority</span>
                <select class="form-select" @bind="priority">
                    <option value="">All priorities</option>
                    @foreach (var option in PriorityOptions)
                    {
                        <option value="@option">@option</option>
                    }
                </select>
            </label>

            <label>
                <span>Hospital</span>
                <select class="form-select" @bind="hospitalId">
                    <option value="">All hospitals</option>
                    @foreach (var hospital in hospitals)
                    {
                        <option value="@hospital.Id">@hospital.Name</option>
                    }
                </select>
            </label>

            <label>
                <span>Insurance company</span>
                <select class="form-select" @bind="insuranceCompanyId">
                    <option value="">All companies</option>
                    @foreach (var company in insuranceCompanies)
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                </select>
            </label>
        </div>

        <div class="filter-actions">
            <button class="btn btn-primary" type="submit" disabled="@isLoading">Search</button>
            <button class="btn btn-outline-secondary" type="button" @onclick="ClearFiltersAsync" disabled="@isLoading">Clear</button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="results-summary">
        <span>@SummaryText</span>
        @if (isLoading)
        {
            <span class="loading-label">Loading...</span>
        }
    </div>

    <div class="table-shell">
        <table class="table claims-table">
            <thead>
                <tr>
                    <th>Claim</th>
                    <th>Provider / payer</th>
                    <th>Service</th>
                    <th class="text-end">Balance</th>
                    <th>Priority</th>
                    <th>Recommendation</th>
                    <th>Decision</th>
                </tr>
            </thead>
            <tbody>
                @if (claims.Count == 0 && !isLoading)
                {
                    <tr>
                        <td colspan="7" class="empty-state">No claims match the current filters.</td>
                    </tr>
                }
                else
                {
                    @foreach (var claim in claims)
                    {
                        <tr>
                            <td>
                                <a class="claim-link" href="@($"claims/{claim.Id}")">@claim.ClaimNumber</a>
                                <span class="muted-line">@claim.PatientIdentifier</span>
                            </td>
                            <td>
                                <span>@GetHospitalName(claim.HospitalId)</span>
                                <span class="muted-line">@GetInsuranceCompanyName(claim.InsuranceCompanyId)</span>
                            </td>
                            <td>
                                <span>@FormatDate(claim.DateOfService)</span>
                                <span class="muted-line">@claim.CalculatedValues.ClaimAgeDays days old</span>
                            </td>
                            <td class="text-end">
                                <span class="money">@FormatMoney(claim.OutstandingBalance)</span>
                                @if (claim.UnderpaymentAmount is not null)
                                {
                                    <span class="muted-line">@FormatMoney(claim.UnderpaymentAmount.Value) underpaid</span>
                                }
                            </td>
                            <td>
                                <span class="@GetPriorityClass(claim.Priority)">@claim.Priority</span>
                                <span class="muted-line">@claim.CalculatedValues.Urgency urgency</span>
                            </td>
                            <td>
                                <span>@(claim.LatestRecommendation?.RecommendedAction ?? "Not analyzed")</span>
                                @if (!string.IsNullOrWhiteSpace(claim.LatestRecommendation?.Explanation))
                                {
                                    <span class="muted-line explanation">@claim.LatestRecommendation.Explanation</span>
                                }
                            </td>
                            <td>
                                <span class="@GetStatusClass(claim.Status)">@FormatStatus(claim.Status)</span>
                                <span class="muted-line">@(claim.LatestRecommendation?.DecisionStatus ?? "Pending")</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="pager">
        <button class="btn btn-outline-secondary" type="button" @onclick="PreviousPageAsync" disabled="@(isLoading || !pagedClaims.HasPreviousPage)">Previous</button>
        <span>Page @pagedClaims.PageNumber of @Math.Max(pagedClaims.TotalPages, 1)</span>
        <button class="btn btn-outline-secondary" type="button" @onclick="NextPageAsync" disabled="@(isLoading || !pagedClaims.HasNextPage)">Next</button>
    </div>
</section>

@code {
    private static readonly string[] StatusOptions =
    [
        "New",
        "InReview",
        "Recommended",
        "InProgress",
        "Recovered",
        "Closed"
    ];

    private static readonly string[] PriorityOptions =
    [
        "Low",
        "Normal",
        "High",
        "Urgent"
    ];

    private readonly Dictionary<long, string> hospitalNames = [];
    private readonly Dictionary<long, string> insuranceCompanyNames = [];
    private readonly List<MedicalClaimResponse> claims = [];
    private readonly int pageSize = 25;

    private IReadOnlyCollection<HospitalResponse> hospitals = [];
    private IReadOnlyCollection<InsuranceCompanyResponse> insuranceCompanies = [];
    private PagedMedicalClaimResponse pagedClaims = new() { PageNumber = 1, PageSize = 25 };
    private string? search;
    private string? status;
    private string? priority;
    private string? hospitalId;
    private string? insuranceCompanyId;
    private string? errorMessage;
    private bool isLoading;

    private string SummaryText => pagedClaims.TotalCount == 1
        ? "1 claim"
        : $"{pagedClaims.TotalCount} claims";

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
        await LoadClaimsAsync();
    }

    private async Task SearchClaimsAsync()
    {
        pagedClaims.PageNumber = 1;
        await LoadClaimsAsync();
    }

    private async Task ClearFiltersAsync()
    {
        search = null;
        status = null;
        priority = null;
        hospitalId = null;
        insuranceCompanyId = null;
        pagedClaims.PageNumber = 1;
        await LoadClaimsAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (!pagedClaims.HasPreviousPage)
        {
            return;
        }

        pagedClaims.PageNumber--;
        await LoadClaimsAsync();
    }

    private async Task NextPageAsync()
    {
        if (!pagedClaims.HasNextPage)
        {
            return;
        }

        pagedClaims.PageNumber++;
        await LoadClaimsAsync();
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            var hospitalTask = Http.GetFromJsonAsync<IReadOnlyCollection<HospitalResponse>>("api/hospitals");
            var insuranceTask = Http.GetFromJsonAsync<IReadOnlyCollection<InsuranceCompanyResponse>>("api/insurance-companies");

            hospitals = await hospitalTask ?? [];
            insuranceCompanies = await insuranceTask ?? [];

            hospitalNames.Clear();
            foreach (var hospital in hospitals)
            {
                hospitalNames[hospital.Id] = hospital.Name;
            }

            insuranceCompanyNames.Clear();
            foreach (var company in insuranceCompanies)
            {
                insuranceCompanyNames[company.Id] = company.Name;
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Lookup data could not be loaded. Start the API project and refresh the page.";
        }
    }

    private async Task LoadClaimsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.GetFromJsonAsync<PagedMedicalClaimResponse>(BuildClaimsRequestUri());
            pagedClaims = response ?? new PagedMedicalClaimResponse { PageNumber = 1, PageSize = pageSize };
            claims.Clear();
            claims.AddRange(pagedClaims.Items);
        }
        catch (HttpRequestException exception)
        {
            claims.Clear();
            pagedClaims = new PagedMedicalClaimResponse { PageNumber = 1, PageSize = pageSize };
            errorMessage = exception.StatusCode == HttpStatusCode.BadRequest
                ? "One or more filters are invalid."
                : "Claims could not be loaded. Start the API project and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string BuildClaimsRequestUri()
    {
        var query = new List<string>
        {
            $"pageNumber={pagedClaims.PageNumber}",
            $"pageSize={pageSize}"
        };

        AddQueryValue(query, "search", search);
        AddQueryValue(query, "status", status);
        AddQueryValue(query, "priority", priority);
        AddQueryValue(query, "hospitalId", hospitalId);
        AddQueryValue(query, "insuranceCompanyId", insuranceCompanyId);

        return $"api/medical-claims?{string.Join("&", query)}";
    }

    private static void AddQueryValue(List<string> query, string name, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            query.Add($"{name}={Uri.EscapeDataString(value.Trim())}");
        }
    }

    private string GetHospitalName(long id)
    {
        return hospitalNames.TryGetValue(id, out var name) ? name : $"Hospital #{id}";
    }

    private string GetInsuranceCompanyName(long id)
    {
        return insuranceCompanyNames.TryGetValue(id, out var name) ? name : $"Company #{id}";
    }

    private static string FormatDate(DateOnly date)
    {
        return date.ToString("MMM d, yyyy", CultureInfo.InvariantCulture);
    }

    private static string FormatMoney(decimal value)
    {
        return value.ToString("C0", CultureInfo.GetCultureInfo("en-US"));
    }

    private static string FormatStatus(string value)
    {
        return value switch
        {
            "InReview" => "In review",
            "InProgress" => "In progress",
            _ => value
        };
    }

    private static string GetPriorityClass(string priority)
    {
        return priority switch
        {
            "Urgent" => "badge priority urgent",
            "High" => "badge priority high",
            "Low" => "badge priority low",
            _ => "badge priority normal"
        };
    }

    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Recovered" or "Closed" => "badge status complete",
            "Recommended" => "badge status recommended",
            "InProgress" or "InReview" => "badge status active",
            _ => "badge status neutral"
        };
    }
}
